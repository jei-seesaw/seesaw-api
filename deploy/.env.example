IMAGE=<dockerhub-namespace>/seesaw-api:main
APP_ENV=dev
PORT=9093
HOST_BIND=127.0.0.1
HOST_PORT=9093
DB_HOST=mariadb
DB_PORT=3306
DB_USER=seesaw
DB_PASSWORD=<strong-password>
DB_NAME=seesaw
CORS_ORIGINS=https://app.example.com,https://admin.example.com
JWT_ACCESS_SECRET=<strong-access-secret>
JWT_REFRESH_SECRET=<strong-refresh-secret>
MARIADB_ROOT_PASSWORD=<strong-root-password>
