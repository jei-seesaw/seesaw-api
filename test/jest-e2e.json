{
  "moduleFileExtensions": ["js", "json", "ts"],
  "maxWorkers": 1,
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "extensionsToTreatAsEsm": [".ts"],
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": {
          "module": "ESNext",
          "moduleResolution": "node"
        },
        "useESM": true
      }
    ]
  }
}
